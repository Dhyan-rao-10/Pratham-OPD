# Gemini (free — used for OCR vision extraction and report generation)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# On-shore / self-hosted vision model for OCR (DPDP-clean — PHI never leaves your
# network). Tried FIRST in the vision chain, before Gemini/Groq/OpenAI. e.g. an
# Ollama-served Qwen2.5-VL exposing an OpenAI-compatible /chat/completions endpoint.
# Leave BASE_URL unset to disable and use the cloud fallbacks. API key only if your
# server requires one. See llm_client.complete_with_image for the fallback order.
# LOCAL_VISION_BASE_URL=http://host.docker.internal:11434/v1
# LOCAL_VISION_MODEL=qwen2.5vl:7b
# LOCAL_VISION_API_KEY=
# LOCAL_VISION_TIMEOUT=60

# OCR brand→generic normalization: maps Indian brand names read off uploaded
# prescriptions (Crocin, Augmentin, Pan-D…) to their formal generic name.
# Set to false to disable instantly (OCR reverts to showing names exactly as
# written). Non-destructive — the original brand is always kept. Default: true.
OCR_NORMALIZE_BRANDS=true

# OCR upload guards (defaults shown). Reject oversized files / decompression bombs.
# OCR_MAX_UPLOAD_MB=15
# OCR_MAX_DIM=12000
# How many PDF pages to read (multi-page lab reports/discharge summaries). Pages are
# stacked into one image; keep modest so the combined image stays legible. Default 5.
# OCR_PDF_MAX_PAGES=5

# Fuzzy tolerance for matching a written ALLERGY term to a drug class (so a
# misspelled/loose "pennicilin" / "penicillin allergy" still contraindicates
# penicillins). Lower = looser. Safety path — a missed allergy is worse than an
# extra caution the doctor can dismiss. Default 0.82.
# ALLERGY_FUZZY_CUTOFF=0.82

# Per-call LLM provider timeout in seconds (default 60).
# LLM_TIMEOUT_SECONDS=60

# Groq — free fallback LLM (OpenAI-compatible). Generous free tier (~1000 req/day),
# used automatically when the Gemini free-tier quota runs out. Get a free key at
# https://console.groq.com/keys . Model override optional (default llama-3.3-70b-versatile).
GROQ_API_KEY=your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic
ANTHROPIC_API_KEY=your_key_here

# OpenAI (for Whisper transcription in Ambient Scribe)
OPENAI_API_KEY=your_key_here

# Bhashini ASR — in-app Ambient Scribe speech-to-text (MeitY/Dhruva pipeline).
# WITHOUT THESE, STT IS SIMPLY OFF (no fallback) — the Scribe records audio but
# returns no transcript, and /api/transcribe/health reports {"bhashini": false}.
# Get keys from your Bhashini / ULCA account (a Udyat key + an inference API key).
# BHASHINI_INFERENCE_API_KEY is REQUIRED to enable ASR; BHASHINI_UDYAT_KEY is used
# to discover the live serviceId per language and for translation.
BHASHINI_UDYAT_KEY=your_udyat_key_here
BHASHINI_INFERENCE_API_KEY=your_inference_key_here
# Optional — sane defaults, override only if Bhashini changes them:
# BHASHINI_PIPELINE_ID=64392f96daac500b55c543cd
# BHASHINI_POSTPROCESSORS=itn,punctuation
# BHASHINI_STAGE2_LLM=false   # opt-in LLM cleanup of the raw transcript

# Twilio (sandbox)
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890
# §8a — the inbound WhatsApp webhook validates X-Twilio-Signature against the
# account auth token. Twilio signs the exact public URL it POSTs to; if the
# reverse proxy rewrites host/proto and validation fails, pin the exact URL here.
# Validation is skipped (dry-run, with a warning) only when the Twilio creds above
# are unset/placeholder. e.g. TWILIO_WEBHOOK_URL=https://opd.hospital.in/api/whatsapp/webhook
# TWILIO_WEBHOOK_URL=

# §8b — login brute-force lockout (doctor PIN + admin passcode), Redis-backed.
# LOGIN_MAX_ATTEMPTS failures per identifier within LOGIN_LOCKOUT_SECONDS => 429
# until the window expires. Defaults shown.
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_SECONDS=900

# PostgreSQL — CHANGE POSTGRES_PASSWORD before any real deployment.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=opd_preconsult
POSTGRES_USER=opd_user
POSTGRES_PASSWORD=changeme_in_production

# Redis
REDIS_URL=redis://redis:6379

# Timezone that defines a "service day" — the daily queue-token counter resets at
# LOCAL midnight in this zone (not the DB server's UTC midnight). Default IST.
# APP_TIMEZONE=Asia/Kolkata

# How long an UNFINISHED visit keeps blocking the same patient (name+phone) from
# re-registering. A visit abandoned mid-flow is never dispatched/removed, so
# without a cutoff it would block that person forever. Default 12h; 0 disables.
# ACTIVE_VISIT_WINDOW_HOURS=12

# Drug-name fuzzy matching (OCR/spelling near-misses like "amoxillin"->amoxicillin
# so interaction/allergy checks still fire). Higher cutoff = stricter (0-1).
# DRUG_FUZZY_CUTOFF=0.86
# DRUG_FUZZY_MIN_LEN=6

# MinIO — CHANGE MINIO_ACCESS_KEY / MINIO_SECRET_KEY before any real deployment.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_in_production
MINIO_BUCKET=opd-documents
# Encryption at rest (B1) — REQUIRED in production (docker-compose.prod.yml).
# Format: <key-name>:<base64 of 32 random bytes>. Run `node scripts/gen-secrets.js`.
# When set, uploaded PHI (documents, audio) is encrypted on disk (SSE-S3).
# BACK THIS KEY UP — losing it makes encrypted objects unreadable. Leave BLANK in
# dev for no encryption. If you set it in dev, MinIO gets it too (both read .env).
MINIO_KMS_SECRET_KEY=

# Generate strong values for ALL secrets below at once: node scripts/gen-secrets.js
#
# JWT — REQUIRED, shared by node-backend AND python-backend (python verifies the
# SAME login token). Node refuses to start in production without a strong value.
# In dev, node uses a random ephemeral key when unset — but then python cannot
# verify tokens, so you MUST set this in dev too now that python auth is on.
JWT_SECRET=changeme_in_production_use_256bit_random_string
# Optional — binds OTP hashes. Defaults to JWT_SECRET when unset.
# OTP_SECRET=
# CORS — lock the python-backend to your domain in production (comma-separated).
# Default '*' is fine for local dev. e.g. CORS_ALLOW_ORIGINS=https://opd.hospital.in
# CORS_ALLOW_ORIGINS=

# §8c — per-client-IP rate limits on the expensive/abusable python endpoints
# (Redis-backed, fail-open if Redis is down). Defaults shown; override per bucket
# with RATELIMIT_<BUCKET>_MAX / RATELIMIT_<BUCKET>_WINDOW (seconds). Set MAX=0 to
# disable a bucket. Buckets: OCR_PROCESS (20/60), REPORT_GENERATE (20/60),
# SCRIBE (30/60), MEDIA (240/60 — signed image/audio routes).
# RATELIMIT_OCR_PROCESS_MAX=20
# RATELIMIT_REPORT_GENERATE_MAX=20
# RATELIMIT_SCRIBE_MAX=30
# RATELIMIT_MEDIA_MAX=240

# Admin passcode for the HIS dashboard login (shared credential; per-user admin
# accounts / SSO is a later decision). Must be >=6 chars. Change before production.
ADMIN_PASSCODE=changeme_admin_passcode

# Signing key for short-lived media URLs (document images, voice clips). These
# routes are consumed as <img src>/<audio src> and can't carry a JWT, so their
# URLs carry an HMAC signature instead. Defaults to JWT_SECRET when unset.
# MEDIA_URL_SECRET=
# How long a minted media URL stays valid, seconds (default 900 = 15 min).
# MEDIA_URL_TTL_SECONDS=900

# HIS Webhook. The receiver (POST /his/fhir/bundle) requires this as a bearer
# token and refuses to accept bundles when it is unset.
HIS_WEBHOOK_URL=http://node-backend:4001/his/fhir/bundle
HIS_WEBHOOK_TOKEN=mock_token_for_poc

# §6b — data retention. When > 0, a background worker HARD-erases sessions (all
# PHI rows across every table + their MinIO objects, leaving a PHI-free audit
# tombstone) once they are older than this many days. Default 0 = disabled (no
# automatic deletion). Admins can also erase a single session on demand via
# DELETE /api/admin/erase/:session_id regardless of this setting.
# RETENTION_DAYS=0

# Demo questionnaire seeding — LOCAL/TESTING ONLY, leave unset in production.
# When true, node-backend seeds the demo cardiology/general DAG questions on boot
# into departments coded CARD / GEN. A real hospital would plausibly code its
# cardiology department CARD, which is all it takes for demo questions to land in
# a live department's intake — so this is off unless explicitly opted in.
# SEED_DEMO_QUESTIONS=true

# Which hospital this deployment serves. Both names below must hold the SAME id.
#
# HOSPITAL_ID is read at RUNTIME by node-backend, and is only consulted where the
# id can't come from the request: a WhatsApp-initiated visit has no QR to carry
# ?h=<hospital_id>, so the webhook stamps its sessions with this.
# NEXT_PUBLIC_HOSPITAL_ID is baked into the frontend at BUILD time and is the
# fallback when someone opens the app with no ?h= (a bare-domain QR).
# Leave both unset for the single-tenant demo default (demo_hospital_01).
#
# (These replace DEMO_HOSPITAL_ID / DEMO_HOSPITAL_NAME, which no code ever read —
# setting them looked like configuring the hospital and silently did nothing.)
# HOSPITAL_ID=demo_hospital_01
# NEXT_PUBLIC_HOSPITAL_ID=demo_hospital_01
# REQUIRED for real use — HMAC-signs prescription QR slips. node-backend refuses
# to start in production with a weak/default value (forgeable prescriptions).
QR_SIGNING_SECRET=changeme_qr_secret
# §8d — how many days a prescription QR stays valid (verify-qr rejects older
# slips using the signed issued_at). Default 30; set 0 to disable the expiry check.
# QR_EXPIRY_DAYS=30
